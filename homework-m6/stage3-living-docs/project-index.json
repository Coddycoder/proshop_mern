{
  "name": "proshop_mern",
  "type": "fullstack-monorepo",
  "description": "MERN e-commerce fork (Brad Traversy, intentionally legacy) extended for the HSS AI-dev course with two Python MCP servers, a Python RAG pipeline, a feature-flags layer, and an M4 design-system redesign.",
  "tech_stack": {
    "backend": "Node 20 + Express 4.17 + Mongoose 5 (ES modules)",
    "frontend": "React 16 + classic Redux + redux-thunk + react-router-dom v5 (CRA, react-scripts 3.4.3)",
    "database": "MongoDB (Mongoose 5)",
    "mcp": "Python 3 (uv) FastMCP — feature-flags + search-docs servers",
    "rag": "Python — sentence-transformers BGE-M3 embeddings + Qdrant vector DB",
    "payments": "PayPal JS SDK (react-paypal-button-v2)"
  },
  "subprojects": {
    "backend": {
      "path": "backend/",
      "description": "Express REST API: products, users, orders, uploads, feature-flags read API. Mongoose models, JWT auth, server-side price calc.",
      "entry": "backend/server.js",
      "port": 5001,
      "tech": "Node 20 + Express 4.17 + Mongoose 5 (ESM — local imports need .js)",
      "key_paths": {
        "server": "backend/server.js",
        "config": "backend/config/db.js",
        "controllers": "backend/controllers/",
        "routes": "backend/routes/",
        "middleware": "backend/middleware/authMiddleware.js",
        "models": "backend/models/",
        "utils": "backend/utils/generateToken.js",
        "seeder": "backend/seeder.js",
        "feature_flags_state": "backend/features.json"
      }
    },
    "frontend": {
      "path": "frontend/",
      "description": "Create React App SPA: storefront + admin + the M4 Feature Dashboard. Classic Redux (no RTK), localStorage rehydrate.",
      "entry": "frontend/src/index.js",
      "port": 3000,
      "tech": "React 16 + Redux + redux-thunk + react-router v5",
      "key_paths": {
        "app_shell": "frontend/src/App.js",
        "store": "frontend/src/store.js",
        "design_tokens": "frontend/src/index.css",
        "actions": "frontend/src/actions/",
        "reducers": "frontend/src/reducers/",
        "screens": "frontend/src/screens/",
        "components": "frontend/src/components/",
        "feature_dashboard": "frontend/src/screens/FeatureDashboardScreen.js"
      }
    },
    "feature_flags_mcp": {
      "path": "mcp-servers/feature-flags/",
      "description": "Feature-flags MCP server (write-path). Tools: list_features, get_feature_info, set_feature_state, adjust_traffic_rollout. Atomic writes + dependency validation over backend/features.json. Sole legitimate writer of features.json.",
      "entry": "mcp-servers/feature-flags/server.py",
      "tech": "Python 3 (uv) + FastMCP (stdio; optional http/sse for n8n)",
      "spec": "docs/specs/feature-flags-mcp-spec.md",
      "key_paths": {
        "server": "mcp-servers/feature-flags/server.py",
        "scenario": "mcp-servers/feature-flags/run_search_v2_scenario.py",
        "state_file": "backend/features.json"
      }
    },
    "search_docs_mcp": {
      "path": "mcp-servers/search-docs/",
      "description": "Docs-search MCP server. Tool: search_project_docs(query, top_k, kind). Vector search over the project-data corpus via the rag/ retrieval module (Qdrant + BGE-M3).",
      "entry": "mcp-servers/search-docs/server.py",
      "tech": "Python 3 (uv) + MCP; delegates retrieval to rag/query.py",
      "spec": "docs/specs/search-docs-mcp-spec.md",
      "key_paths": {
        "server": "mcp-servers/search-docs/server.py"
      }
    },
    "rag": {
      "path": "rag/",
      "description": "RAG pipeline. ingest.py embeds docs/chunks.jsonl with BGE-M3 and upserts into Qdrant (collection proshop_docs). query.py embeds a query and searches. Backs the search-docs MCP.",
      "entry": "rag/query.py",
      "tech": "Python — sentence-transformers BGE-M3 (1024-dim) + Qdrant",
      "spec": "docs/specs/rag-pipeline-spec.md",
      "key_paths": {
        "ingest": "rag/ingest.py",
        "query": "rag/query.py",
        "ingest_input": "docs/chunks.jsonl",
        "chunking_spec": "docs/chunking-spec.md"
      }
    },
    "feature_flags_layer": {
      "path": "backend/features.json",
      "description": "Shared feature-flags store. Read by Express (GET /api/feature-flags), written ONLY by the feature-flags MCP, also driven by n8n Auto-Pilot. See ADR-006.",
      "spec": "docs/specs/feature-flags-backend-spec.md",
      "key_paths": {
        "state": "backend/features.json",
        "read_api": "backend/controllers/featureFlagsController.js",
        "write_api": "mcp-servers/feature-flags/server.py"
      }
    }
  },
  "system_folders": {
    ".claude/": "Claude Code config: agent definitions, scripts, local settings + hooks",
    ".claude/agents/": "Sub-agent definitions (security/performance/architecture/legacy-auditor/test-writer mates)",
    ".claude/scripts/": "Automation scripts (update_project_index.py keeps this file's filesystem_tree fresh)",
    "docs/": "Living documentation root (README index, architecture/, specs/, adr/)",
    "docs/project-data/": "LIVE RAG knowledge corpus (47 md). Chunked into docs/chunks.jsonl, embedded into Qdrant, served by the search-docs MCP. Do not move/archive.",
    "docs/specs/": "Per-module reverse-engineering specs (4-step pattern: overview/decision-table/sequence/edge-cases).",
    "docs/adr/": "Architecture Decision Records (adr-001..007). Numbering is preserved; do not restart.",
    "docs/architecture/": "High-level system overview (C4 + MCP/RAG/feature-flags).",
    "uploads/": "User-uploaded files, served at /uploads (ephemeral on Heroku)."
  },
  "root_files": {
    "CLAUDE.md": "Project rules for AI agents (commands, ESM, architecture, git workflow, MCP usage). START HERE.",
    "DESIGN.md": "M4 design system — single source of truth for the UI visual language.",
    "README.md": "Project overview, setup, run instructions.",
    "package.json": "Backend (root) npm scripts: dev/server/client, data:import/destroy.",
    "Procfile": "Legacy Heroku deploy config — out of scope, do not touch.",
    ".mcp.json": "MCP server registration (feature-flags + search-docs).",
    ".env": "Local secrets (git-ignored): NODE_ENV, PORT, MONGO_URI, JWT_SECRET, PAYPAL_CLIENT_ID.",
    "project-index.json": "This file — machine-readable repo map. Read FIRST.",
    "homework-m6/": "M6 homework submission (code-review, fixes, living docs, tests agent)."
  },
  "hard_rules": [
    "ALWAYS read project-index.json FIRST at session start for repo orientation.",
    "Read CLAUDE.md for rules and DESIGN.md before touching any frontend file (UI single source of truth).",
    "NEVER edit backend/features.json directly — mutate it ONLY through the feature-flags MCP (atomic writes + dependency validation). Direct edits desync the Dashboard.",
    "For documentation questions, query the search-docs MCP (search_project_docs) FIRST — do not grep docs/project-data/.",
    "Backend uses ES modules: local file imports MUST include the .js extension.",
    "Do NOT casually upgrade pinned legacy deps (React 16, Mongoose 5, redux-thunk, react-router v5, react-scripts 3.4.3).",
    "Preserve behavior on refactors — write characterization tests FIRST (see homework-m6/stage2-fix-top3/tests/).",
    "Conventional Commits; develop on a feature branch, squash-merge to master, push master only.",
    "Keep project-index.json current — run .claude/scripts/update_project_index.py after structural changes (or rely on the PostToolUse hook)."
  ],
  "ai_routing": {
    "feature_flag_status": "feature-flags MCP get_feature_info / list_features (NOT direct features.json reads)",
    "feature_flag_changes": "feature-flags MCP set_feature_state / adjust_traffic_rollout",
    "docs_search": "search-docs MCP search_project_docs (NOT grep over docs/project-data/)",
    "structure_questions": "this project-index.json (do not walk the filesystem)",
    "module_deep_dive": "docs/specs/<module>-spec.md",
    "code_questions": "backend/controllers/ + backend/routes/ + frontend/src/",
    "ui_design_questions": "DESIGN.md + frontend/src/index.css",
    "architecture_overview": "docs/architecture/overview.md"
  },
