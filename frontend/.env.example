# Feature Dashboard Auto-Pilot (M5) — n8n WF1 webhook.
# Copy this file to `frontend/.env` and restart `npm run client` (CRA only reads
# REACT_APP_* env vars at build/start time).
#
# Base URL of the n8n webhook (no trailing slash). AutoPilotControls appends
# `/feature-control`. For self-hosted Docker n8n on this machine:
REACT_APP_N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Must match the Header Auth credential value bound to the WF1 Webhook node
# (n8n: Settings -> Credentials -> Header Auth, header name X-API-Key).
# Generate with: openssl rand -hex 32
# NOTE: shipping this key in the frontend bundle is an M5 simplification — in
# production the frontend would call its own backend, which holds the key.
REACT_APP_N8N_API_KEY=replace-me-with-strong-random-string
